# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=             # e.g. https://admin.yourdomain.com

# AI — provide at least one
OPENAI_API_KEY=           # OpenAI key for GPT-4o summarization
ANTHROPIC_API_KEY=        # Anthropic key for Claude (optional alternative)

# Notifications
RESEND_API_KEY=           # Resend key for email notifications
TELEGRAM_BOT_TOKEN=       # Telegram bot token for in-app notifications

# Webhook auth (shared secret between bot and admin panel)
WEBHOOK_SECRET=           # any random string, e.g. openssl rand -hex 32
