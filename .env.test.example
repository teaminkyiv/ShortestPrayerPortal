# Copy to .env.test and fill in real values from your test database.
# .env.test is git-ignored — never commit it.

# App
BASE_URL=http://localhost:3000
TEST_ADMIN_PASSWORD=           # same value as ADMIN_PANEL_PASSWORD in .env
WEBHOOK_SECRET=                # same value as WEBHOOK_SECRET in .env

# Test DB record UUIDs — seed these records before running tests
TEST_TESTIMONY_ID=             # any testimony (any status)
TEST_NEW_TESTIMONY_ID=         # testimony with status 'new' in testimony_reviews
TEST_SUMMARIZED_TESTIMONY_ID=  # testimony with status 'summarized' (used for draft save / empty-publish check)
TEST_FOR_PUBLISH_TESTIMONY_ID= # testimony with status 'summarized' (used for publish test — will be mutated)
TEST_FRESH_SUMMARIZED_TESTIMONY_ID= # testimony with status 'summarized', edited_version = NULL (used for pre-fill test)
TEST_PUBLISHED_TESTIMONY_ID=   # testimony with status 'published'
